---
import CTASection from "../components/CTASection.astro";
import MainLayout from "../layouts/MainLayout.astro";
import PageIntro from "../components/PageIntro.astro";
import SectionBlock from "../components/SectionBlock.astro";
import SparkModelDiagram from "../components/SparkModelDiagram.astro";

const sparkPillars = [
  {
    title: "Social",
    definition: "Trust, coordination, and relational steadiness in the workforce.",
    signals: ["Coordination slows when trust weakens", "Retention risk rises when relationships carry too much strain"],
    impact: "Weak Social conditions reduce execution quality and increase relational drag.",
  },
  {
    title: "Purpose",
    definition: "Direction, decision logic, and the business meaning behind the work.",
    signals: ["Teams lose alignment without repeated clarification", "Priorities become harder to interpret consistently"],
    impact: "Weak Purpose conditions create drift and reduce strategic coherence.",
  },
  {
    title: "Achievement",
    definition: "Whether progress is visible, credible, and supported by the system.",
    signals: ["Follow-through weakens when progress feels opaque", "Recognition loses credibility"],
    impact: "Weak Achievement conditions reduce momentum and accomplishment.",
  },
  {
    title: "Risk",
    definition: "Thoughtful challenge, experimentation, and psychological safety under uncertainty.",
    signals: ["People hesitate to question assumptions when error feels punitive", "Innovation slows when experimentation feels exposed"],
    impact: "Weak Risk conditions suppress voice, constrain learning, and increase burnout exposure.",
  },
  {
    title: "Knowledge",
    definition: "How information, documentation, and practical guidance move through the organization.",
    signals: ["Guidance is scattered across people and tools", "Performance suffers when context is missing"],
    impact: "Weak Knowledge conditions create repeated errors and fragility.",
  },
];

const sparkUses = [
  "Use SPARK as an employee engagement framework that connects survey language to real system conditions.",
  "Use SPARK as a retention strategy model that helps leaders see which conditions are pushing good people out.",
  "Use SPARK as an operating system for redesign so consulting recommendations stay tied to measurable business outcomes.",
];
---

<MainLayout
  title="SPARK Framework | Employee Engagement Framework & Retention Strategy Model | NSBS"
  description="Explore the SPARK Framework from NSBS, a workforce consulting model for employee engagement, retention strategy, leadership development, and organizational performance."
>
  <PageIntro
    eyebrow="SPARK Framework"
    title="An employee engagement framework and retention strategy model for workforce systems"
    description="SPARK is not just a conceptual model. It works as both a diagnostic framework and an operating system for workforce consulting, employee engagement, retention strategy, leadership development, and organizational performance decisions."
    supportingPoints={[
      "Diagnostic and operating system",
      "Built for business outcomes",
      "Designed for structural clarity",
    ]}
  />

  <SectionBlock
    eyebrow="Framework role"
    title="What SPARK helps a leader see"
    intro="SPARK helps leaders interpret workforce conditions as system-generated rather than treating engagement, retention, or performance variability as isolated morale problems."
  >
    <div class="split-layout">
      <div class="narrative-block">
        <p>
          In practical terms, SPARK gives workforce consulting work a clearer structure. It helps
          leadership teams understand where employee engagement is weakening, where retention
          strategy needs stronger design, and where performance variability or risk hesitation is
          being generated by the system itself.
        </p>
        <p>
          That is what makes SPARK useful to business advocacy. It gives leaders a disciplined way
          to connect human outcomes to structural conditions and to make better decisions about what
          should change first.
        </p>
      </div>

      <div class="content-panel">
        <ul class="signal-list compact">
          {sparkUses.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </SectionBlock>

  <SectionBlock
    eyebrow="Five conditions"
    title="The five conditions SPARK measures"
    intro="Each pillar reflects a different dimension of workforce health, but the model is strongest when leaders read them together as one workforce system. In SPARK, Risk is not only about preventing harm. It also measures whether challenge, experimentation, and learning are structurally supported."
  >
    <SparkModelDiagram />

    <div class="card-grid spark-grid spark-grid--dense">
      {sparkPillars.map((pillar) => (
        <article class="card pillar-card pillar-card--dense">
          <div class="card-title-row">
            <h3>{pillar.title}</h3>
            <p class="body small">{pillar.definition}</p>
          </div>
          <ul class="signal-list compact">
            {pillar.signals.map((signal) => <li>{signal}</li>)}
          </ul>
          <p class="body small pillar-impact">{pillar.impact}</p>
        </article>
      ))}
    </div>
  </SectionBlock>

  <SectionBlock
    eyebrow="Business use"
    title="How SPARK supports consulting and advocacy"
    intro="SPARK gives NSBS a measured way to connect employee engagement, retention strategy, leadership development, and organizational performance to the same structural logic."
  >
    <div class="card-grid three-up">
      <article class="card">
        <div class="card-title-row">
          <p class="small-label mono-label">For diagnosis</p>
          <h3>Surface conditions early</h3>
          <p>Use SPARK to identify where engagement problems are really clarity, workload, documentation, or coordination problems.</p>
        </div>
      </article>

      <article class="card">
        <div class="card-title-row">
          <p class="small-label mono-label">For redesign</p>
          <h3>Translate findings into action</h3>
          <p>Use SPARK to organize redesign decisions so workforce consulting does not drift into broad recommendations without operating logic.</p>
        </div>
      </article>

      <article class="card">
        <div class="card-title-row">
          <p class="small-label mono-label">For measurement</p>
          <h3>Track business outcomes</h3>
          <p>Use SPARK to make retention, employee engagement, and organizational performance easier to monitor as measurable conditions.</p>
        </div>
      </article>
    </div>
  </SectionBlock>

  <CTASection
    title="Use SPARK as the system behind the next decision"
    body="If you need a clearer starting point for workforce consulting, employee engagement, retention strategy, or leadership development work, SPARK can provide the structure."
    actionHref="/assessment"
    actionLabel="Begin Assessment"
    secondaryHref="/business-lab"
    secondaryLabel="Enter the Business Lab"
  />
</MainLayout>
