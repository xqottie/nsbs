---
import CTASection from "../components/CTASection.astro";
import HeroSection from "../components/HeroSection.astro";
import WorkforceObservatory from "../components/business-lab/WorkforceObservatory.astro";
import WorkforceRoiEstimator from "../components/business-lab/WorkforceRoiEstimator.astro";
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Business Lab | Workforce Observatory & ROI Estimator | NSBS"
  description="Use the NSBS Business Lab to explore the live Workforce Observatory and the Workforce Engagement ROI Estimator for clearer workforce diagnostics, engagement analysis, and retention decision support."
>
  <HeroSection
    className="business-lab-hero"
    eyebrow="Business Laboratory"
    title="Test and Simulate Workforce Conditions"
    body="The Business Lab now brings the live Workforce Observatory and the Workforce Engagement ROI Estimator into the site as working tools. Review current workforce conditions across SPARK, then model the directional annual value of improving engagement, retention, and system design."
    actions={[
      { href: "#observatory-tool", label: "Open the Observatory" },
      { href: "#roi-estimator", label: "Run the ROI Estimator", variant: "secondary" },
    ]}
  >
    <p class="eyebrow mono-label">Decision support</p>
    <h2 class="subhead hero-aside-title">
      Read the live signal first, then translate it into business impact.
    </h2>
    <ul class="signal-list compact">
      <li>Compare workforce pressure across Social, Purpose, Achievement, Risk, and Knowledge.</li>
      <li>Review source-linked metrics and latest signal entries inside the observatory.</li>
      <li>Estimate annual value from improved engagement, retention, and reduced friction.</li>
    </ul>
    <p class="body small hero-aside-note">
      The tools are directional and practical: built to support better conversations, better
      diagnostics, and better operating decisions.
    </p>
  </HeroSection>

  <WorkforceObservatory />
  <WorkforceRoiEstimator />

  <CTASection
    title="Turn tool output into a grounded workforce diagnostic"
    body="Use NSBS to translate observatory signals and ROI estimates into a more accurate systems view for your organization. We can identify where pressure is structural, what it is costing, and what to redesign first."
    actionHref="/assessment"
    actionLabel="Begin Assessment"
    secondaryHref="/contact"
    secondaryLabel="Start a Conversation"
  />
</MainLayout>

<style>
  .business-lab-hero .hero-title {
    max-width: 11.8ch;
  }

  .business-lab-hero .hero-body {
    max-width: 45rem;
  }
</style>
