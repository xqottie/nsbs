---
import CTASection from "../components/CTASection.astro";
import MainLayout from "../layouts/MainLayout.astro";
import SectionBlock from "../components/SectionBlock.astro";
import SparkModelDiagram from "../components/SparkModelDiagram.astro";
import StructuralFirstComparisonDiagram from "../components/StructuralFirstComparisonDiagram.astro";

const recognitionSignals = [
  "Turnover stays high despite training",
  "Managers carry invisible strain",
  "Teams work hard but priorities collide",
  "New hires struggle to ramp",
  "Good people leave because the system keeps exhausting them",
];

const methodCards = [
  {
    title: "Diagnose",
    body: "Assess workforce conditions, friction points, and where pressure or uncertainty are distorting performance.",
  },
  {
    title: "Design",
    body: "Map findings into practical structural interventions tied to measurable outcomes.",
  },
  {
    title: "Stabilize",
    body: "Support implementation, governance, and ongoing recalibration to reduce drift.",
  },
];

const approachPreview = [
  {
    title: "Workforce Systems Architecture",
    body: "Organizational outcomes are shaped by the structure people work inside, not effort alone.",
  },
  {
    title: "Structural First Principle",
    body: "Structural mechanisms should be evaluated before behavior change efforts are asked to carry the load.",
  },
  {
    title: "SPARK as operating system",
    body: "A practical model for reading workforce conditions and organizing redesign decisions.",
  },
];

const sparkPillars = [
  {
    title: "Social",
    definition: "Trust, coordination, and relational steadiness across the workforce.",
    signals: ["Isolation increases", "Handoffs depend on extra repair work"],
    impact: "Weak Social conditions slow coordination and make collaboration expensive.",
  },
  {
    title: "Purpose",
    definition: "Clarity about direction, meaning, and how effort connects to strategy.",
    signals: ["Teams lose priority clarity", "Decision drift increases"],
    impact: "Weak Purpose conditions create ambiguity and uneven decision quality.",
  },
  {
    title: "Achievement",
    definition: "Whether the system supports visible progress and credible accomplishment.",
    signals: ["Progress is hard to verify", "Recognition becomes inconsistent"],
    impact: "Weak Achievement conditions reduce momentum and confidence.",
  },
  {
    title: "Risk",
    definition: "The conditions that support thoughtful challenge, experimentation, and learning under uncertainty.",
    signals: ["Experimentation feels costly", "Voice narrows when stakes rise"],
    impact: "Weak Risk conditions suppress challenge, slow innovation, and raise burnout exposure.",
  },
  {
    title: "Knowledge",
    definition: "How information, guidance, and practical understanding move through the system.",
    signals: ["Guidance is scattered", "Errors repeat because context is missing"],
    impact: "Weak Knowledge conditions create confusion and institutional fragility.",
  },
];

const credibilityPoints = [
  "Workforce systems thinking that connects people outcomes to structure, governance, and operating conditions.",
  "A trauma-informed perspective that pays attention to pressure, supported challenge, and the lived cost of harmful instability.",
  "Instructional design and facilitation experience that helps translation happen without oversimplifying the problem.",
  "Strategy and development experience that keeps redesign tied to execution, not just diagnosis.",
  "Measurable frameworks that make progress visible and keep interventions grounded in evidence.",
];
---

<MainLayout
  title="Business Advocacy for Workforce Systems | Workforce Consulting & Retention Strategy | NSBS"
  description="NSBS combines business advocacy with workforce consulting to improve employee engagement, retention strategy, leadership development, and organizational performance through the SPARK Model."
>
  <section class="section home-hero">
    <div class="container home-hero-grid">
      <div class="home-hero-copy">
        <p class="eyebrow mono-label">Northern Spark Business Solutions, L3C</p>
        <h1 class="display home-hero-title">Sustainable Workforce Performance by Design</h1>
        <p class="lede home-hero-body">
          We help organizations strengthen the conditions that support people, performance, and
          long-term stability. Not through quick fixes, but through systems that actually work.
        </p>
        <div class="button-row home-hero-actions">
          <a class="button button-primary" href="/assessment">Start with a 10-minute assessment</a>
          <a class="button button-secondary" href="/spark-framework">Explore the SPARK model</a>
        </div>
      </div>

      <div class="home-hero-visual" aria-label="SPARK system overview">
        <figure class="home-spark-figure">
          <img
            class="home-spark-image"
            src="/images/spark-model-hero.png"
            alt="SPARK model diagram showing Social at the top, then clockwise Purpose, Achievement, Risk, and Knowledge"
            width="1000"
            height="900"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </figure>
      </div>
    </div>
  </section>

  <SectionBlock
    eyebrow="Recognition"
    title="If this feels familiar"
    intro="These patterns show up in organizations that are full of capable people but constrained by unstable design, weak engagement conditions, and retention pressure that looks personal but is often structural."
  >
    <div class="split-layout">
      <div class="content-panel">
        <p class="body small">
          NSBS operates as a business advocate and workforce systems partner, helping organizations
          move beyond standard workforce consulting and employee engagement strategy toward clearer
          retention strategy, leadership development, and organizational performance decisions.
        </p>
        <ul class="signal-list">
          {recognitionSignals.map((signal) => <li>{signal}</li>)}
        </ul>
        <p class="closing-line">These are structural signals, not isolated issues.</p>
      </div>

      <div class="narrative-block">
        <p>
          NSBS helps leaders identify which conditions are creating friction, risk hesitation, and
          hidden cost so redesign efforts can start in the right place and business outcomes can
          improve with more precision.
        </p>
      </div>
    </div>
  </SectionBlock>

  <SectionBlock
    eyebrow="Method"
    title="A disciplined path from diagnosis to steadier performance"
    intro="The work is structured to make workforce consulting, employee engagement decisions, and retention strategy choices easier to read, easier to act on, and easier to sustain."
  >
    <div class="card-grid method-grid">
      {methodCards.map((card) => (
        <article class="card">
          <div class="card-title-row">
            <p class="small-label mono-label">{card.title}</p>
            <p>{card.body}</p>
          </div>
        </article>
      ))}
    </div>
  </SectionBlock>

  <SectionBlock
    eyebrow="Approach preview"
    title="Built around structure before symptom management"
    intro="NSBS works from a clear philosophy: workforce outcomes improve when underlying conditions are better designed, not when organizations rely on generic engagement tactics alone."
  >
    <StructuralFirstComparisonDiagram />

    <div class="card-grid three-up">
      {approachPreview.map((item) => (
        <article class="card">
          <div class="card-title-row">
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </div>
        </article>
      ))}
    </div>
    <div class="section-actions">
      <a class="text-link" href="/approach">Read the advocacy approach</a>
    </div>
  </SectionBlock>

  <SectionBlock
    eyebrow="SPARK"
    title="A practical model for reading workforce conditions"
    intro="SPARK functions as both an employee engagement framework and a retention strategy model, helping leaders read the five conditions shaping workforce performance."
  >
    <SparkModelDiagram />

    <div class="card-grid spark-grid spark-grid--dense">
      {sparkPillars.map((pillar) => (
        <article class="card pillar-card pillar-card--dense">
          <div class="card-title-row">
            <h3>{pillar.title}</h3>
            <p class="body small">{pillar.definition}</p>
          </div>
          <ul class="signal-list compact">
            {pillar.signals.map((signal) => <li>{signal}</li>)}
          </ul>
          <p class="body small pillar-impact">{pillar.impact}</p>
        </article>
      ))}
    </div>
    <div class="button-row section-actions">
      <a class="text-link" href="/spark-framework">Explore the System</a>
      <a class="text-link" href="/assessment">Begin Assessment</a>
    </div>
  </SectionBlock>

  <SectionBlock
    eyebrow="Business Lab"
    title="A practical environment for testing workforce conditions and intervention paths"
    intro="The Business Lab translates observatory intelligence into a more business-facing decision environment. It helps leaders use workforce analysis to examine engagement conditions, retention drivers, and the structural choices shaping organizational performance."
  >
    <div class="card-grid two-up compact-feature-grid">
      <article class="card">
        <div class="card-title-row">
          <p class="small-label mono-label">What leaders can do there</p>
          <ul class="signal-list compact">
            <li>Explore workforce conditions in motion</li>
            <li>Reveal friction affecting engagement, performance, and retention</li>
            <li>Compare intervention choices before committing to them</li>
          </ul>
        </div>
      </article>

      <article class="card">
        <div class="card-title-row">
          <p class="small-label mono-label">Why it matters</p>
          <p>
            It is a flagship support environment for serious consulting work, designed to help
            leaders understand where systems hold, where they begin to fail, and which structural
            choices are most likely to improve stability.
          </p>
          <a class="button button-secondary" href="/business-lab">Explore the Business Lab</a>
        </div>
      </article>
    </div>
  </SectionBlock>

  <SectionBlock
    eyebrow="Credibility"
    title="Grounded in disciplined practice, not broad claims"
    intro="NSBS draws from multiple bodies of work to help organizations make better structural decisions with dignity and clarity."
  >
    <div class="card-grid three-up compact-credibility-grid">
      {credibilityPoints.map((point) => (
        <article class="card quiet-card">
          <p>{point}</p>
        </article>
      ))}
    </div>
  </SectionBlock>

  <CTASection
    title="Ready to look at the system more clearly?"
    body="Start with a conversation about the pressures your organization is carrying and the structural conditions shaping them."
    actionHref="/contact"
    actionLabel="Start the Conversation"
  />
</MainLayout>

<style>
  .home-hero {
    padding-top: clamp(6.75rem, 10vw, 8.75rem);
    padding-bottom: clamp(6.25rem, 9.5vw, 8rem);
  }

  .home-hero-grid {
    display: grid;
    gap: clamp(2.25rem, 4.5vw, 5rem);
    align-items: center;
  }

  .home-hero-copy {
    display: grid;
    gap: clamp(1rem, 1.7vw, 1.6rem);
    max-width: 39rem;
    align-content: center;
    padding-right: clamp(0rem, 1.4vw, 1.1rem);
  }

  .home-hero-copy .eyebrow {
    margin-bottom: 0;
    color: var(--muted);
    font-size: clamp(0.82rem, 0.24vw + 0.76rem, 0.88rem);
    font-weight: var(--weight-medium);
    letter-spacing: 0.08em;
  }

  .home-hero-title {
    max-width: 10.4ch;
    font-size: clamp(2.15rem, 1.7rem + 1.95vw, 3.45rem);
    line-height: 0.98;
    letter-spacing: -0.055em;
    text-wrap: balance;
  }

  .home-hero-body {
    max-width: 35rem;
    font-size: clamp(1rem, 0.95rem + 0.38vw, 1.15rem);
    line-height: 1.62;
    color: var(--muted-strong);
  }

  .home-hero-actions {
    gap: 0.8rem;
    padding-top: 0.4rem;
  }

  .home-hero-actions .button {
    min-height: 2.8rem;
    padding: 0.78rem 1.04rem;
    font-size: clamp(0.88rem, 0.84rem + 0.12vw, 0.94rem);
  }

  .home-hero-visual {
    display: grid;
    justify-items: center;
    align-items: center;
    min-width: 0;
  }

  .home-spark-figure {
    width: 100%;
    max-width: 39rem;
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
  }

  .home-spark-image {
    display: block;
    width: auto;
    max-width: 100%;
    height: auto;
    aspect-ratio: auto;
    object-fit: contain;
  }

  @media (min-width: 960px) {
    .home-hero-grid {
      grid-template-columns: minmax(0, 1.2fr) minmax(24rem, 1.2fr);
    }

    .home-hero-visual {
      justify-items: start;
    }

    .home-spark-figure {
      margin-left: clamp(-2.75rem, -4vw, -1rem);
    }
  }

  @media (min-width: 1024px) {
    .home-hero {
      display: grid;
      align-items: center;
      min-height: calc(100vh - (var(--content-scroll-space) * 2));
      padding-top: clamp(4rem, 7vh, 5.5rem);
      padding-bottom: clamp(4.5rem, 8vh, 6rem);
    }

    .home-hero-grid {
      min-height: 100%;
      align-content: center;
    }
  }

  @media (max-width: 959px) {
    .home-hero {
      padding-top: clamp(6rem, 12vw, 7rem);
      padding-bottom: clamp(5.25rem, 10vw, 6.25rem);
    }

    .home-hero-copy {
      max-width: 36rem;
      padding-right: 0;
    }

    .home-spark-figure {
      width: min(100%, 31rem);
    }
  }

  @media (max-width: 640px) {
    .home-hero-grid {
      gap: 2rem;
    }

    .home-hero-title {
      max-width: 10.1ch;
      font-size: clamp(2.02rem, 1.72rem + 1.24vw, 2.46rem);
      line-height: 1.01;
    }

    .home-hero-body {
      max-width: 32rem;
      font-size: clamp(1rem, 0.96rem + 0.3vw, 1.06rem);
      line-height: 1.6;
    }

    .home-hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .home-hero-actions .button {
      width: 100%;
      justify-content: center;
    }

    .home-spark-figure {
      width: min(100%, 27rem);
    }
  }
</style>
