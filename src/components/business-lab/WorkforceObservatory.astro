---
import observatoryModel from "../../data/observatory-model.json";
import {
  PILLAR_ORDER,
  axisPoint,
  escapeJsonForScript,
  formatWholeNumber,
  getRiskBand,
  getScoreMap,
  labelArcPath,
  pillarKey,
  polygonPoints,
  ringPolygonPoints,
  type ObservatoryModel,
  type PillarName,
  wedgePath,
} from "./observatoryLogic";

const model = observatoryModel as ObservatoryModel;

const defaultPillar: PillarName =
  PILLAR_ORDER.find((pillar) => model.pillars[pillar]) ?? PILLAR_ORDER[0];
const detailPillar = model.pillars[defaultPillar];
const scoreMap = getScoreMap(model);
const compositeRisk = getRiskBand(Number(model.composite?.score ?? 0));
const initialMetrics = detailPillar.metrics.slice(0, 6);
const serializedModel = escapeJsonForScript(JSON.stringify(model));

const pillarColorVars: Record<PillarName, string> = {
  Social: "--spark-social",
  Purpose: "--spark-purpose",
  Achievement: "--spark-achievement",
  Risk: "--spark-risk",
  Knowledge: "--spark-knowledge",
};

const radarPillars = PILLAR_ORDER.map((pillar, index) => ({
  pillar,
  pillClass: "obs-pill-score obs-pill-score--" + pillarKey(pillar),
  segmentClass: "obs-ring-segment obs-ring-segment--" + pillarKey(pillar),
  segmentStyle: "--pillar-color: var(" + pillarColorVars[pillar] + ");",
  labelPathId: "obs-segment-path-" + pillarKey(pillar),
  labelClass: "obs-pillar-label obs-pillar-label--" + pillarKey(pillar),
  segmentPath: wedgePath(index),
  labelPath: labelArcPath(index),
  axisPoint: axisPoint(index, 100),
  nodePoint: axisPoint(index, scoreMap[pillar]),
}));
---

<section class="section obs-tool-section" id="observatory-tool" aria-labelledby="observatory-tool-title">
  <div class="container">
    <div class="obs-section-head">
      <div class="obs-section-copy">
        <p class="small-label mono-label">Live tool</p>
        <h2 id="observatory-tool-title">Workforce Observatory</h2>
        <p class="body">
          Review the live SPARK dashboard from the observatory, compare pressure across each
          workforce condition, and move from signal reading into concrete employer action.
        </p>
      </div>

      <div class="obs-section-meta" aria-label="Observatory status">
        <span class="obs-chip">Updated {model.updatedLabel}</span>
        <span class="obs-chip">Confidence {String(model.confidence).toUpperCase()}</span>
      </div>
    </div>

    <section
      class="obs-dashboard card"
      data-observatory-dashboard
      aria-labelledby="observatory-dashboard-title"
    >
      <header class="obs-topbar">
        <div class="obs-topbar-copy">
          <p class="small-label mono-label">Maine Workforce Observatory</p>
          <h3 id="observatory-dashboard-title">SPARK dashboard</h3>
          <p class="body small">{model.composite.summary}</p>
        </div>

        <div class="obs-topbar-summary" aria-label="Composite SPARK summary">
          <div class="obs-composite-block">
            <span class="obs-chip-label">Composite SPARK Score</span>
            <p class="obs-composite-readout">
              <strong data-composite-score>{formatWholeNumber(model.composite.score)}</strong>
              <span>/ 100</span>
            </p>
          </div>

          <span class={"obs-risk-band obs-risk-band--" + compositeRisk.band} data-composite-band>
            {compositeRisk.label}
          </span>
          <span class="obs-chip" data-composite-confidence>
            Confidence {String(model.confidence).toUpperCase()}
          </span>
        </div>
      </header>

      <div class="obs-main-grid">
        <article class="obs-radar-card">
          <div class="obs-radar-head">
            <div>
              <p class="small-label mono-label">SPARK Radar</p>
              <h3>Compare all five pillars at once</h3>
            </div>

            <div class="obs-pill-score-row" aria-label="Pillar scores">
              {radarPillars.map((item) => (
                <span class={item.pillClass}>
                  <strong>{item.pillar[0]}</strong>
                  <span>{formatWholeNumber(model.pillars[item.pillar].score)}</span>
                </span>
              ))}
            </div>
          </div>

          <div class="obs-radar-stage">
            <svg
              class="obs-radar-svg"
              viewBox="-26 -26 412 412"
              role="group"
              aria-labelledby="obs-radar-title"
            >
              <title id="obs-radar-title">
                SPARK radar with selectable pillar segments
              </title>

              <g class="obs-ring-segments" aria-label="Selectable SPARK pillar segments">
                {radarPillars.map((item) => (
                  <path
                    d={item.segmentPath}
                    class={item.segmentClass}
                    data-pillar-button={item.pillar}
                    style={item.segmentStyle}
                    role="button"
                    tabindex="0"
                    aria-pressed={item.pillar === defaultPillar ? "true" : "false"}
                  />
                ))}
              </g>

              <defs>
                {radarPillars.map((item) => (
                  <path id={item.labelPathId} d={item.labelPath} />
                ))}
              </defs>

              <g class="obs-radar-rings">
                <polygon points={ringPolygonPoints(0.25)} />
                <polygon points={ringPolygonPoints(0.5)} />
                <polygon points={ringPolygonPoints(0.75)} />
                <polygon points={ringPolygonPoints(1)} />
              </g>

              <g class="obs-radar-axes">
                {radarPillars.map((item) => (
                  <line
                    x1="180"
                    y1="180"
                    x2={item.axisPoint.x.toFixed(1)}
                    y2={item.axisPoint.y.toFixed(1)}
                    data-pentagon-axis={item.pillar}
                  />
                ))}
              </g>

              <polygon
                class="obs-shape"
                data-pentagon-shape
                points={polygonPoints(scoreMap)}
              />

              <g class="obs-radar-nodes">
                {radarPillars.map((item) => (
                  <circle
                    cx={item.nodePoint.x.toFixed(1)}
                    cy={item.nodePoint.y.toFixed(1)}
                    r="4.5"
                    data-pentagon-node={item.pillar}
                  />
                ))}
              </g>

              <g class="obs-segment-labels" aria-hidden="true">
                {radarPillars.map((item) => (
                  <text class={item.labelClass} data-pillar-label={item.pillar}>
                    <textPath
                      href={"#" + item.labelPathId}
                      startOffset="50%"
                      text-anchor="middle"
                    >
                      {item.pillar.toUpperCase()}
                    </textPath>
                  </text>
                ))}
              </g>
            </svg>
          </div>

          <div class="obs-pillars-nav" role="tablist" aria-label="Select a SPARK pillar">
            {PILLAR_ORDER.map((pillar) => (
              <button
                type="button"
                class:list={["obs-pillar-tab", pillar === defaultPillar && "is-selected"]}
                data-pillar-tab={pillar}
                aria-selected={pillar === defaultPillar ? "true" : "false"}
                aria-pressed={pillar === defaultPillar ? "true" : "false"}
              >
                <span class="obs-pillar-tab-dot" data-pillar={pillarKey(pillar)}></span>
                <span>{pillar}</span>
              </button>
            ))}
          </div>
        </article>

        <article class="obs-detail-card card" aria-live="polite">
          <header class="obs-detail-head">
            <div class="obs-detail-title-row">
              <h3 class="obs-detail-title">
                <span
                  class="obs-pillar-bullet"
                  data-detail-pillar-bullet
                  data-pillar={pillarKey(defaultPillar)}
                  aria-hidden="true"
                ></span>
                <span data-detail-title data-pillar={pillarKey(defaultPillar)}>
                  {detailPillar.title}
                </span>
              </h3>

              <p class="obs-detail-score">
                <span data-detail-band>{formatWholeNumber(detailPillar.score)}</span>
                <span data-detail-band-scale> / 100</span>
              </p>
            </div>
          </header>

          <section class="obs-detail-block">
            <p class="small-label mono-label">Signal summary</p>
            <p class="body small" data-detail-summary>{detailPillar.signalSummary}</p>
          </section>

          <section class="obs-detail-block">
            <p class="small-label mono-label">What this means for employers</p>
            <ul class="signal-list compact" data-detail-employer-bullets>
              {detailPillar.employerImplications.slice(0, 3).map((item) => <li>{item}</li>)}
            </ul>
          </section>

          <section class="obs-detail-block">
            <p class="small-label mono-label">Recommended actions</p>
            <ul class="signal-list compact" data-detail-actions>
              {detailPillar.recommendedActions.slice(0, 3).map((item) => <li>{item}</li>)}
            </ul>
          </section>

          <section class="obs-detail-block obs-detail-sources">
            <p class="small-label mono-label">Source context</p>
            <div class="obs-source-chip-row" data-detail-source-chips>
              {detailPillar.sourceChips.slice(0, 6).map((chip) => (
                <span class="obs-source-chip">{chip}</span>
              ))}
            </div>
            <p
              class="obs-detail-updated body small"
              data-detail-source-updated
              hidden={!detailPillar.sourceUpdatedLabel || detailPillar.sourceUpdatedLabel === "Unknown"}
            >
              Last updated: {detailPillar.sourceUpdatedLabel}
            </p>
          </section>
        </article>
      </div>

      <div class="obs-lower-grid">
        <article class="obs-panel-card card">
          <header class="obs-panel-head">
            <div>
              <p class="small-label mono-label">Data & sources</p>
              <h3>Metrics behind the pillar signal</h3>
            </div>

            <div class="obs-panel-head-actions">
              <p class="obs-panel-pill" data-metrics-pillar-label>{defaultPillar}</p>
              <button
                type="button"
                class="obs-toggle-button"
                data-metrics-toggle
                aria-pressed="false"
              >
                View all pillars
              </button>
            </div>
          </header>

          <div class="obs-metrics-grid" data-metrics-grid>
            {initialMetrics.map((metric) => (
              <article class="obs-metric-card card">
                <p class="obs-metric-label">{metric.label}</p>
                <div class="obs-metric-value-row">
                  <p class="obs-metric-value">{metric.value}</p>
                  {metric.unit && <p class="obs-metric-unit">{metric.unit}</p>}
                  <span class={"obs-metric-status obs-metric-status--" + metric.status.toLowerCase()}>
                    {metric.status}
                  </span>
                </div>
                {metric.trendLabel && <p class="obs-metric-trend">{metric.trendLabel}</p>}
                <div class="obs-metric-meta-row">
                  <p class="obs-metric-meta">Updated {metric.timeframe}</p>
                  {
                    metric.sourceUrl ? (
                      <a
                        class="obs-metric-source"
                        href={metric.sourceUrl}
                        target="_blank"
                        rel="noreferrer noopener"
                        title={metric.sourceLabel}
                      >
                        {metric.sourceLabel}
                        <span aria-hidden="true">↗</span>
                      </a>
                    ) : (
                      <span class="obs-metric-source">{metric.sourceLabel}</span>
                    )
                  }
                </div>
              </article>
            ))}
          </div>

          <p class="body small obs-empty-state" data-metrics-empty hidden={initialMetrics.length > 0}>
            No metric cards are available for this pillar.
          </p>
        </article>

        <article class="obs-panel-card card">
          <header class="obs-panel-head">
            <div>
              <p class="small-label mono-label">Observatory feed</p>
              <h3>Latest signal entries</h3>
            </div>
          </header>

          <div class="obs-feed-filters" role="tablist" aria-label="Filter observatory signals">
            <button type="button" class="is-selected" data-signal-filter="All" aria-selected="true" aria-pressed="true">
              All
            </button>
            {PILLAR_ORDER.map((pillar) => (
              <button
                type="button"
                data-signal-filter={pillar}
                aria-selected="false"
                aria-pressed="false"
              >
                {pillar}
              </button>
            ))}
          </div>

          <ul class="obs-feed-list" data-signal-list>
            {model.signals.map((signal) => (
              <li class="obs-feed-row" data-signal-item data-signal-pillar={signal.pillar}>
                <div class="obs-feed-row-top">
                  <span class="obs-feed-date">{signal.dateLabel}</span>
                  <span class="obs-feed-pillar" data-pillar={pillarKey(signal.pillar)}>
                    {signal.pillar}
                  </span>
                </div>
                <h3 class="obs-feed-title">{signal.title}</h3>
                <p class="obs-feed-summary">{signal.summary}</p>
                {
                  signal.sourceUrl ? (
                    <a
                      class="obs-feed-source"
                      href={signal.sourceUrl}
                      target="_blank"
                      rel="noreferrer noopener"
                    >
                      {signal.sourceLabel}
                      <span aria-hidden="true">↗</span>
                    </a>
                  ) : (
                    <span class="obs-feed-source">{signal.sourceLabel}</span>
                  )
                }
              </li>
            ))}
          </ul>
        </article>
      </div>

      <footer class="obs-footer">
        <div class="obs-footer-copy">
          <p class="small-label mono-label">Source cluster</p>
          <p class="body small">
            Review the current data cluster powering this snapshot and use it as directional
            context rather than a prediction engine.
          </p>
        </div>

        <div class="obs-footer-sources">
          {model.sourceCluster.map((source) => (
            <a
              class="obs-source-link"
              href={source.url}
              target="_blank"
              rel="noreferrer noopener"
            >
              {source.label}
            </a>
          ))}
        </div>
      </footer>
    </section>
  </div>

  <script type="application/json" id="observatory-view-model" set:html={serializedModel}></script>

  <script>
    import { initWorkforceObservatory } from "./observatoryClient";

    initWorkforceObservatory();
  </script>
</section>

<style>
  .obs-tool-section {
    padding-top: var(--section-space-tight);
  }

  .obs-section-head,
  .obs-section-copy,
  .obs-topbar,
  .obs-topbar-copy,
  .obs-main-grid,
  .obs-lower-grid,
  .obs-radar-card,
  .obs-detail-card,
  .obs-detail-block,
  .obs-panel-card,
  .obs-panel-head,
  .obs-footer,
  .obs-footer-copy {
    display: grid;
    gap: var(--panel-gap);
  }

  .obs-section-head {
    gap: var(--grid-gap);
    margin-bottom: var(--space-4);
  }

  .obs-section-copy {
    max-width: 46rem;
  }

  .obs-section-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .obs-chip,
  .obs-panel-pill,
  .obs-source-chip,
  .obs-feed-pillar,
  .obs-pill-score,
  .obs-risk-band {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    width: fit-content;
    min-height: 1.9rem;
    padding: 0.32rem 0.62rem;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.86);
    color: var(--muted-strong);
    font-family: var(--font-mono);
    font-size: var(--text-mono);
    line-height: 1.35;
    letter-spacing: var(--tracking-mono);
    text-transform: uppercase;
  }

  .obs-dashboard {
    gap: var(--space-4);
    padding: clamp(1rem, 0.9rem + 0.85vw, 1.8rem);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(247, 250, 247, 0.9)),
      linear-gradient(135deg, rgba(47, 111, 94, 0.04), transparent 42%);
  }

  .obs-topbar {
    gap: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--line);
  }

  .obs-topbar-summary {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    align-items: start;
    justify-content: flex-start;
  }

  .obs-composite-block {
    display: grid;
    gap: 0.3rem;
  }

  .obs-chip-label {
    color: var(--muted);
    font-size: var(--text-meta);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .obs-composite-readout {
    display: flex;
    gap: 0.35rem;
    align-items: baseline;
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.8rem, 2vw, 2.25rem);
    line-height: 1;
  }

  .obs-composite-readout strong {
    font-weight: var(--weight-semibold);
    letter-spacing: -0.05em;
  }

  .obs-risk-band--low {
    border-color: rgba(47, 111, 94, 0.18);
    background: rgba(47, 111, 94, 0.1);
    color: var(--accent);
  }

  .obs-risk-band--moderate {
    border-color: rgba(201, 162, 39, 0.24);
    background: rgba(201, 162, 39, 0.12);
    color: #7e6215;
  }

  .obs-risk-band--high {
    border-color: rgba(184, 92, 92, 0.24);
    background: rgba(184, 92, 92, 0.1);
    color: #8c4242;
  }

  .obs-risk-band--neutral {
    background: rgba(95, 107, 118, 0.08);
  }

  .obs-radar-card,
  .obs-panel-card {
    align-content: start;
  }

  .obs-radar-head,
  .obs-detail-title-row,
  .obs-panel-head-actions,
  .obs-metric-value-row,
  .obs-metric-meta-row,
  .obs-feed-row-top {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: baseline;
    justify-content: space-between;
  }

  .obs-pill-score-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .obs-pill-score strong {
    color: var(--text-strong);
  }

  .obs-radar-stage {
    position: relative;
    width: min(100%, 26rem);
    margin-inline: auto;
  }

  .obs-radar-svg {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .obs-radar-rings polygon,
  .obs-radar-axes line {
    fill: none;
    stroke: rgba(31, 42, 51, 0.1);
    stroke-width: 1.15;
  }

  .obs-ring-segment {
    cursor: pointer;
    fill: color-mix(in srgb, var(--pillar-color) 8%, white);
    stroke: color-mix(in srgb, var(--pillar-color) 52%, white);
    stroke-width: 1.2;
    opacity: 0.74;
    transition:
      opacity 0.2s ease,
      fill 0.2s ease,
      transform 0.2s ease;
    transform-origin: 180px 180px;
  }

  .obs-ring-segment.is-active,
  .obs-ring-segment.is-selected,
  .obs-ring-segment:hover,
  .obs-ring-segment:focus-visible {
    opacity: 1;
    fill: color-mix(in srgb, var(--pillar-color) 18%, white);
  }

  .obs-shape {
    fill: rgba(47, 111, 94, 0.16);
    stroke: rgba(47, 111, 94, 0.55);
    stroke-width: 2.3;
  }

  .obs-radar-nodes circle {
    fill: var(--surface);
    stroke: rgba(47, 111, 94, 0.45);
    stroke-width: 2;
    transition: transform 0.2s ease, fill 0.2s ease;
    transform-origin: center;
  }

  .obs-radar-nodes circle.is-active {
    fill: var(--accent);
    transform: scale(1.15);
  }

  .obs-radar-axes line.is-active {
    stroke: rgba(47, 111, 94, 0.42);
    stroke-width: 1.8;
  }

  .obs-pillar-label {
    fill: rgba(31, 42, 51, 0.68);
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.22em;
  }

  .obs-pillar-label.is-active,
  .obs-pillar-label.is-selected {
    fill: var(--text-strong);
  }

  .obs-pillars-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .obs-pillar-tab,
  .obs-feed-filters button,
  .obs-toggle-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    min-height: 2.1rem;
    padding: 0.45rem 0.75rem;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.92);
    color: var(--text-strong);
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .obs-pillar-tab.is-selected,
  .obs-feed-filters button.is-selected,
  .obs-toggle-button:hover,
  .obs-toggle-button:focus-visible {
    border-color: rgba(47, 111, 94, 0.28);
    background: rgba(47, 111, 94, 0.08);
    color: var(--accent);
  }

  .obs-pillar-tab-dot,
  .obs-pillar-bullet {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
    background: var(--accent);
    flex-shrink: 0;
  }

  .obs-pillar-tab-dot[data-pillar="social"],
  .obs-pillar-bullet[data-pillar="social"],
  .obs-feed-pillar[data-pillar="social"] {
    background: var(--spark-social);
  }

  .obs-pillar-tab-dot[data-pillar="purpose"],
  .obs-pillar-bullet[data-pillar="purpose"],
  .obs-feed-pillar[data-pillar="purpose"] {
    background: var(--spark-purpose);
  }

  .obs-pillar-tab-dot[data-pillar="achievement"],
  .obs-pillar-bullet[data-pillar="achievement"],
  .obs-feed-pillar[data-pillar="achievement"] {
    background: var(--spark-achievement);
  }

  .obs-pillar-tab-dot[data-pillar="risk"],
  .obs-pillar-bullet[data-pillar="risk"],
  .obs-feed-pillar[data-pillar="risk"] {
    background: var(--spark-risk);
  }

  .obs-pillar-tab-dot[data-pillar="knowledge"],
  .obs-pillar-bullet[data-pillar="knowledge"],
  .obs-feed-pillar[data-pillar="knowledge"] {
    background: var(--spark-knowledge);
  }

  .obs-detail-title {
    display: inline-flex;
    gap: 0.55rem;
    align-items: center;
  }

  .obs-detail-score {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(1.35rem, 1.2vw + 1rem, 1.65rem);
    line-height: 1;
  }

  .obs-source-chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .obs-detail-updated {
    margin-top: 0.25rem;
  }

  .obs-panel-card {
    gap: 1rem;
  }

  .obs-metrics-grid {
    display: grid;
    gap: 0.85rem;
  }

  .obs-metric-card {
    gap: 0.65rem;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.9);
  }

  .obs-metric-label,
  .obs-metric-value,
  .obs-metric-unit,
  .obs-metric-trend,
  .obs-metric-meta,
  .obs-metric-source,
  .obs-feed-date,
  .obs-feed-summary,
  .obs-feed-source {
    margin: 0;
  }

  .obs-metric-value {
    color: var(--text-strong);
    font-size: 1.2rem;
    font-weight: var(--weight-semibold);
  }

  .obs-metric-unit {
    color: var(--muted);
    font-size: var(--text-small);
  }

  .obs-metric-status {
    padding: 0.2rem 0.45rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: var(--text-mono);
    text-transform: uppercase;
  }

  .obs-metric-status--ok {
    border-color: rgba(47, 111, 94, 0.16);
