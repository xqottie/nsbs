---
const {
  eyebrow = "Next step",
  title,
  body,
  actionHref,
  actionLabel,
  secondaryHref,
  secondaryLabel,
} = Astro.props;
---

<section class="section">
  <div class="container">
    <div class="cta-panel">
      <div class="cta-copy">
        <p class="small-label mono-label cta-eyebrow">{eyebrow}</p>
        <h2 class="section-title">{title}</h2>
        <p class="lede">{body}</p>
      </div>

      <div class="button-row">
        <a class="button button-primary" href={actionHref}>{actionLabel}</a>
        {secondaryHref && secondaryLabel && <a class="button button-secondary" href={secondaryHref}>{secondaryLabel}</a>}
      </div>
    </div>
  </div>
</section>
